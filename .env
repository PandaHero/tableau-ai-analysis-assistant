# ========================================
# 服务器配置
# ========================================

# 后端服务器
HOST=127.0.0.1
PORT=8000

# 前端服务器
VITE_APP_HOST=127.0.0.1
VITE_APP_PORT=5173

# CORS配置
CORS_ORIGINS=https://127.0.0.1:5173,https://localhost:5173

# SSL配置（开发环境使用自签名证书）
SSL_CERT_FILE=cert.pem
SSL_KEY_FILE=key.pem
FRONTEND_SSL_CERT_FILE=cert.pem
FRONTEND_SSL_KEY_FILE=key.pem


# ========================================
# Tableau API 配置
# ========================================

# Tableau Server 域名（公司内部服务器）
TABLEAU_DOMAIN=https://cpse.cpgroup.cn:11080
TABLEAU_BASE_URL=https://cpse.cpgroup.cn:11080

# Tableau站点名称（从URL中的 #/site/ZF 获取）
TABLEAU_SITE=ZF

# Tableau API版本（Tableau Server 2025.1.5）
TABLEAU_API_VERSION=3.15

# Tableau用户名
TABLEAU_USER=tableauAdmin

# JWT认证配置（从 Tableau Server 获取）
TABLEAU_JWT_CLIENT_ID=5d50aad9-f6ea-4ece-b76e-155e9d7b3750
TABLEAU_JWT_SECRET_ID=e3095bfe-a831-4641-ab78-59f40073ab75
TABLEAU_JWT_SECRET=1em+PLubDGMtA/yXILXHgt2q6u+9PyryC4KQeOa308=

# PAT认证配置（备用）
TABLEAU_PAT_NAME=agent
TABLEAU_PAT_SECRET=OvkUm63QRHixUKO/UYTMEA==:0FajC67oI204OU7m1P9sozrQhMPp9x6f

# 数据源LUID
DATASOURCE_LUID=dd01d2bd-bc89-4478-9ad5-656ca9d506cf


# ========================================
# LLM 配置
# ========================================

# ============ 当前使用的 LLM（切换开关）============
# 可选值: deepseek | qwen3
ACTIVE_LLM=qwen3

# ============ DeepSeek 配置 ============
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL_PROVIDER=openai
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=sk-f02e477c366f44f692b11450abb514f6

# ============ Qwen3 配置（公司内部）============
QWEN3_API_BASE=http://36.212.5.18:9997/v1
QWEN3_MODEL_PROVIDER=local
QWEN3_MODEL_NAME=qwen3
QWEN3_API_KEY=dummy-key

# ============ 实际使用的配置（根据 ACTIVE_LLM 自动选择）============
# 注意：下面的配置会根据 ACTIVE_LLM 的值自动设置
# 如果 ACTIVE_LLM=deepseek，使用 DeepSeek 配置
# 如果 ACTIVE_LLM=qwen3，使用 Qwen3 配置

# 当前激活的配置（手动切换时修改这里）
LLM_API_BASE=http://36.212.5.18:9997/v1
LLM_MODEL_PROVIDER=local
TOOLING_LLM_MODEL=qwen3
LLM_API_KEY=dummy-key

# ========================================
# SSL/TLS 证书配置
# ========================================

# SSL验证开关
# - true: 启用SSL证书验证（生产环境推荐）
# - false: 禁用SSL证书验证（仅用于开发调试）
LLM_VERIFY_SSL=true

# 自定义CA证书路径（可选）
# 如果系统证书库无法验证API证书，可以指定自定义证书文件
# 示例：
#   Windows开发环境: tableau_assistant/certs/tableau_cpse_cpgroup_cn_cert.pem
#   CentOS生产环境: /opt/tableau-assistant/certs/deepseek_full_chain.pem
LLM_CA_BUNDLE=tableau_assistant/certs/tableau_cpse_cpgroup_cn_cert.pem


# ========================================
# 日期处理配置
# ========================================

# 周开始日：0=周一（ISO标准，中国习惯），6=周日（美国标准）
WEEK_START_DAY=0

# SetFilter阈值（uniqueCount小于此值时，STRING类型日期字段使用SetFilter）
SET_FILTER_THRESHOLD=50


# ========================================
# 缓存配置
# ========================================

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 元数据缓存时间（秒）
METADATA_CACHE_TTL=3600

# 维度层级缓存时间（秒）
DIMENSION_HIERARCHY_CACHE_TTL=86400


# ========================================
# 性能配置
# ========================================

# 最大重规划轮数
MAX_REPLAN_ROUNDS=2

# 并行查询上限
PARALLEL_UPPER_LIMIT=3

# 最大重试次数
MAX_RETRY_TIMES=3

# 每轮最大子任务数
MAX_SUBTASKS_PER_ROUND=10


# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/tableau_assistant.log
