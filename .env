# ========================================
# 服务器配置
# ========================================

# 后端服务器
HOST=127.0.0.1
PORT=8000

# 前端服务器
VITE_APP_HOST=127.0.0.1
VITE_APP_PORT=5173

# CORS配置
CORS_ORIGINS=https://127.0.0.1:5173,https://localhost:5173

# SSL配置（用于启动 HTTPS 服务器）
# 注意：这是服务器端证书，和客户端证书验证（LLM_CA_BUNDLE）不同
# 后端 HTTPS 服务器证书（已迁移到证书管理器）
SSL_CERT_FILE=tableau_assistant/certs/app_server.pem
SSL_KEY_FILE=tableau_assistant/certs/app_server_key.pem
# 前端 HTTPS 服务器证书（已迁移到证书管理器）
FRONTEND_SSL_CERT_FILE=tableau_assistant/certs/app_server.pem
FRONTEND_SSL_KEY_FILE=tableau_assistant/certs/app_server_key.pem


# ========================================
# Tableau API 配置
# ========================================

# Tableau Cloud 域名
TABLEAU_DOMAIN=https://10ax.online.tableau.com
TABLEAU_BASE_URL=https://10ax.online.tableau.com

# Tableau站点名称（从URL中的 #/site/tianci 获取）
TABLEAU_SITE=tianci

# Tableau API版本（Tableau Server 2025.1.5）
TABLEAU_API_VERSION=3.24

# Tableau用户名
TABLEAU_USER=675051285@qq.com

# JWT认证配置（从 Tableau Server 获取）
TABLEAU_JWT_CLIENT_ID=26d90937-4a99-40c6-a1f0-1e67aeb1b024
TABLEAU_JWT_SECRET_ID=6c547515-eb4d-4621-b304-43a878ae35b6
TABLEAU_JWT_SECRET=77tNRwxD3IfCzA6IXsXn6YE4iwGhpiDmW1HNP4noqXc=

# PAT认证配置（备用）
TABLEAU_PAT_NAME=agent
TABLEAU_PAT_SECRET=vdCVGcOtS52CyPw6h+4Cig==:jDuvVDls4rnICxPRFHSfVqlW6VpBRPEa

# 数据源LUID
DATASOURCE_LUID=e99f1815-b3b8-4660-9624-946ea028338f

# ========================================
# Embeddings 配置
# ========================================

# 智谱 AI Embedding API Key
ZHIPUAI_API_KEY=b418bbdd992949e092f41df890e08f40.tDfChKbpqsZSSFx5


# ========================================
# LLM 配置
# ========================================

# ============ 当前使用的 LLM（切换开关）============
# 可选值: deepseek | qwen3
ACTIVE_LLM=qwen3

# ============ DeepSeek 配置 ============
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL_PROVIDER=openai
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=sk-f02e477c366f44f692b11450abb514f6

# ============ Qwen3 配置（公司内部）============
QWEN3_API_BASE=http://36.212.5.18:9997/v1
QWEN3_MODEL_PROVIDER=local
QWEN3_MODEL_NAME=qwen3
QWEN3_API_KEY=dummy-key

# ============ 实际使用的配置（根据 ACTIVE_LLM 自动选择）============
# 注意：下面的配置会根据 ACTIVE_LLM 的值自动设置
# 如果 ACTIVE_LLM=deepseek，使用 DeepSeek 配置
# 如果 ACTIVE_LLM=qwen3，使用 Qwen3 配置

# 当前激活的配置（手动切换时修改这里）
LLM_API_BASE=http://36.212.5.18:9997/v1
LLM_MODEL_PROVIDER=local
TOOLING_LLM_MODEL=qwen3
LLM_API_KEY=dummy-key

# ========================================
# SSL/TLS 证书配置
# ========================================

# SSL验证开关
# - true: 启用SSL证书验证（生产环境推荐）
# - false: 禁用SSL证书验证（仅用于开发调试）
LLM_VERIFY_SSL=true

# ========================================
# 日期处理配置
# ========================================

# 周开始日：0=周一（ISO标准，中国习惯），6=周日（美国标准）
WEEK_START_DAY=0



# ========================================
# 缓存配置
# ========================================

# 元数据缓存时间（秒）
METADATA_CACHE_TTL=3600

# 维度层级缓存时间（秒）
DIMENSION_HIERARCHY_CACHE_TTL=86400

# ========================================
# 中间件配置 (Middleware)
# ========================================

# SummarizationMiddleware - 对话历史自动总结
# 根据模型上下文长度调整，预留30%给输出
# - Claude 3.5: 200K context → threshold ~60K
# - DeepSeek: 64K context → threshold ~20K
# - Qwen: 32K context → threshold ~10K
SUMMARIZATION_TOKEN_THRESHOLD=20000
MESSAGES_TO_KEEP=10

# RetryMiddleware - LLM/工具调用失败自动重试
MODEL_MAX_RETRIES=3
TOOL_MAX_RETRIES=3

# FilesystemMiddleware - 大结果自动转存阈值（tokens）
FILESYSTEM_TOKEN_LIMIT=20000

# HumanInTheLoopMiddleware - 需要人工确认的工具（逗号分隔，留空禁用）
# 示例: INTERRUPT_ON=write_todos,execute_query
INTERRUPT_ON=

# Replanner - 最大重规划轮数
MAX_REPLAN_ROUNDS=3

# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/tableau_assistant.log
