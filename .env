# ========================================
# LLM 配置
# ========================================

# ============ 当前使用的 LLM（切换开关）============
# 可选值: deepseek-r1 | deepseek | qwen3
ACTIVE_LLM=deepseek-r1

# ============ 自定义 LLM 配置（公司内部部署）============
# 支持各种私有化部署的模型，包括 DeepSeek R1、Qwen 等
# 推理模型，思考过程在 <think>...</think> 标签内
CUSTOM_LLM_API_BASE=https://ai.cpgroup.cn
CUSTOM_LLM_API_ENDPOINT=/api/v1/offline/deep/think
CUSTOM_LLM_MODEL_NAME=deepseek-r1-distill-qwen
CUSTOM_LLM_API_KEY=oxPQEbwRu42AiFKS85sUBg

# 向后兼容（旧配置名称）
DEEPSEEK_R1_API_BASE=https://ai.cpgroup.cn
DEEPSEEK_R1_MODEL_NAME=deepseek-r1-distill-qwen
DEEPSEEK_R1_API_KEY=oxPQEbwRu42AiFKS85sUBg

# ============ DeepSeek 配置（官方 API）============
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL_PROVIDER=openai
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=sk-f02e477c366f44f692b11450abb514f6

# ============ Qwen3 配置（公司内部）============
QWEN3_API_BASE=http://36.212.5.18:9997/v1
QWEN3_MODEL_PROVIDER=local
QWEN3_MODEL_NAME=qwen3
QWEN3_API_KEY=dummy-key

# ============ 实际使用的配置（根据 ACTIVE_LLM 自动选择）============
# 注意：下面的配置会根据 ACTIVE_LLM 的值自动设置
# 如果 ACTIVE_LLM=deepseek-r1，使用公司 DeepSeek R1 配置
# 如果 ACTIVE_LLM=deepseek，使用官方 DeepSeek 配置
# 如果 ACTIVE_LLM=qwen3，使用 Qwen3 配置

# 当前激活的配置（手动切换时修改这里）
LLM_API_BASE=https://ai.cpgroup.cn
LLM_MODEL_PROVIDER=custom
TOOLING_LLM_MODEL=deepseek-r1-distill-qwen
LLM_API_KEY=oxPQEbwRu42AiFKS85sUBg

# ========================================
# SSL/TLS 证书配置
# ========================================

# SSL验证开关
# - true: 启用SSL证书验证（生产环境推荐）
# - false: 禁用SSL证书验证（仅用于开发调试）
LLM_VERIFY_SSL=true


# ========================================
# 缓存配置
# ========================================

# 元数据缓存时间（秒）
METADATA_CACHE_TTL=86400

# 维度层级缓存时间（秒）
DIMENSION_HIERARCHY_CACHE_TTL=86400

# 数据模型缓存时间（秒）
DATA_MODEL_CACHE_TTL=86400

# ========================================
# 中间件配置 (Middleware)
# ========================================

# SummarizationMiddleware - 对话历史自动总结
# 根据模型上下文长度调整，预留30%给输出
# - Claude 3.5: 200K context → threshold ~60K
# - DeepSeek: 64K context → threshold ~20K
# - Qwen: 32K context → threshold ~10K
SUMMARIZATION_TOKEN_THRESHOLD=20000
MESSAGES_TO_KEEP=10

# RetryMiddleware - LLM/工具调用失败自动重试
MODEL_MAX_RETRIES=3
TOOL_MAX_RETRIES=3

# FilesystemMiddleware - 大结果自动转存阈值（tokens）
FILESYSTEM_TOKEN_LIMIT=20000

# HumanInTheLoopMiddleware - 需要人工确认的工具（逗号分隔，留空禁用）
# 示例: INTERRUPT_ON=write_todos,execute_query
INTERRUPT_ON=

# Replanner - 最大重规划轮数
MAX_REPLAN_ROUNDS=3

# ========================================
# LangSmith 追踪配置
# ========================================

# 启用 LangSmith 追踪（true/false）
LANGCHAIN_TRACING_V2=true

# LangSmith API Key
LANGCHAIN_API_KEY=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

# LangSmith 项目名称
LANGCHAIN_PROJECT=analytics-assistant

# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/tableau_assistant.log
