# ========================================
# 服务器配置
# ========================================

# 后端服务器
HOST=127.0.0.1
PORT=8000

# 前端服务器
VITE_APP_HOST=127.0.0.1
VITE_APP_PORT=8000

# CORS配置
CORS_ORIGINS=https://127.0.0.1:5173,https://localhost:5173


# ========================================
# Tableau API 配置
# ========================================

# ============ Tableau 多环境配置 ============
# 支持同时配置多个 Tableau 环境，根据前端传入的域名自动匹配

