TABLEAU_CLOUD_SITE=tianci
TABLEAU_CLOUD_API_VERSION=3.24
TABLEAU_CLOUD_USER=675051285@qq.com
TABLEAU_CLOUD_JWT_CLIENT_ID=26d90937-4a99-40c6-a1f0-1e67aeb1b024
TABLEAU_CLOUD_JWT_SECRET_ID=6c547515-eb4d-4621-b304-43a878ae35b6
TABLEAU_CLOUD_JWT_SECRET=77tNRwxD3IfCzA6IXsXn6YE4iwGhpiDmW1HNP4noqXc=
TABLEAU_CLOUD_PAT_NAME=agent
