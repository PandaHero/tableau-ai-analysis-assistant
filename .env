# 默认数据源（仅用于 Cloud 环境测试，前端会通过数据源名称自动查找 LUID）
DATASOURCE_LUID=e99f1815-b3b8-4660-9624-946ea028338f
# 数值精度：VizQL查询结果中浮点数保留的小数位数（-1表示不处理）
DECIMAL_PRECISION=2

# ========================================
# Embeddings 配置
# ========================================

# 智谱 AI Embedding API Key
ZHIPUAI_API_KEY=b418bbdd992949e092f41df890e08f40.tDfChKbpqsZSSFx5


# ========================================
# LLM 配置
# ========================================

# ============ 当前使用的 LLM（切换开关）============
# 可选值: deepseek | qwen3
ACTIVE_LLM=qwen3

# ============ DeepSeek 配置 ============
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL_PROVIDER=openai
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=sk-f02e477c366f44f692b11450abb514f6

# ============ Qwen3 配置（公司内部）============
QWEN3_API_BASE=http://36.212.5.18:9997/v1
QWEN3_MODEL_PROVIDER=local
QWEN3_MODEL_NAME=qwen3
QWEN3_API_KEY=dummy-key

# ============ 实际使用的配置（根据 ACTIVE_LLM 自动选择）============
# 注意：下面的配置会根据 ACTIVE_LLM 的值自动设置
# 如果 ACTIVE_LLM=deepseek，使用 DeepSeek 配置
# 如果 ACTIVE_LLM=qwen3，使用 Qwen3 配置

# 当前激活的配置（手动切换时修改这里）
LLM_API_BASE=http://36.212.5.18:9997/v1
LLM_MODEL_PROVIDER=local
TOOLING_LLM_MODEL=qwen3
LLM_API_KEY=dummy-key

# ========================================
# SSL/TLS 证书配置
# ========================================

# SSL验证开关
# - true: 启用SSL证书验证（生产环境推荐）
# - false: 禁用SSL证书验证（仅用于开发调试）
LLM_VERIFY_SSL=true

# ========================================
# 日期处理配置
# ========================================

# 周开始日：0=周一（ISO标准，中国习惯），6=周日（美国标准）
WEEK_START_DAY=0

# ========================================
# 缓存配置
# ========================================

# 元数据缓存时间（秒）
METADATA_CACHE_TTL=86400

# 维度层级缓存时间（秒）
DIMENSION_HIERARCHY_CACHE_TTL=86400

# 数据模型缓存时间（秒）
DATA_MODEL_CACHE_TTL=86400

# ========================================
# 中间件配置 (Middleware)
# ========================================

# SummarizationMiddleware - 对话历史自动总结
# 根据模型上下文长度调整，预留30%给输出
# - Claude 3.5: 200K context → threshold ~60K
# - DeepSeek: 64K context → threshold ~20K
# - Qwen: 32K context → threshold ~10K
SUMMARIZATION_TOKEN_THRESHOLD=20000
MESSAGES_TO_KEEP=10

# RetryMiddleware - LLM/工具调用失败自动重试
MODEL_MAX_RETRIES=3
TOOL_MAX_RETRIES=3

# FilesystemMiddleware - 大结果自动转存阈值（tokens）
FILESYSTEM_TOKEN_LIMIT=20000

# HumanInTheLoopMiddleware - 需要人工确认的工具（逗号分隔，留空禁用）
# 示例: INTERRUPT_ON=write_todos,execute_query
INTERRUPT_ON=

# Replanner - 最大重规划轮数
MAX_REPLAN_ROUNDS=3

# ========================================
# LangSmith 追踪配置
# ========================================

# 启用 LangSmith 追踪（true/false）
LANGCHAIN_TRACING_V2=true

# LangSmith API Key
LANGCHAIN_API_KEY=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

# LangSmith 项目名称
LANGCHAIN_PROJECT=tableau-assistant

# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/tableau_assistant.log
