# ========================================
# Tableau API 配置
# ========================================

# Tableau服务器域名
TABLEAU_DOMAIN=your-tableau-server.com

# Tableau站点名称
TABLEAU_SITE=your-site

# Tableau API版本
TABLEAU_API_VERSION=3.21

# Tableau用户名
TABLEAU_USER=your-username

# JWT认证配置
JWT_CLIENT_ID=your-client-id
JWT_SECRET_ID=your-secret-id
JWT_SECRET=your-secret-value

# 数据源LUID
DATASOURCE_LUID=your-datasource-luid


# ========================================
# LLM 配置
# ========================================

# 模型提供商：openai | azure | anthropic | qwen
MODEL_PROVIDER=qwen

# 工具LLM模型
TOOLING_LLM_MODEL=qwen-32b-awq-int4

# LLM API密钥
LLM_API_KEY=your-api-key

# LLM API端点（可选）
LLM_API_ENDPOINT=https://your-llm-endpoint.com


# ========================================
# 日期处理配置
# ========================================

# 周开始日：0=周一（ISO标准，中国习惯），6=周日（美国标准）
# 注意：如果问题中明确提到周开始日（如"周一开始的本周"），以问题为准
WEEK_START_DAY=0

# SetFilter阈值（uniqueCount小于此值时，STRING类型日期字段使用SetFilter）
SET_FILTER_THRESHOLD=50

# 数值精度：VizQL查询结果中浮点数保留的小数位数（-1表示不处理）
DECIMAL_PRECISION=2


# ========================================
# 缓存配置
# ========================================

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 元数据缓存时间（秒）
METADATA_CACHE_TTL=3600

# 维度层级缓存时间（秒）
DIMENSION_HIERARCHY_CACHE_TTL=86400


# ========================================
# 性能配置
# ========================================

# 最大重规划轮数
MAX_REPLAN_ROUNDS=3

# 并行查询上限
PARALLEL_UPPER_LIMIT=3

# 最大重试次数
MAX_RETRY_TIMES=3

# 每轮最大子任务数
MAX_SUBTASKS_PER_ROUND=10


# ========================================
# 中间件配置 (Middleware)
# ========================================

# SummarizationMiddleware - 对话历史自动总结
# 根据模型上下文长度调整，预留30%给输出
# - Claude 3.5: 200K context → threshold ~60K
# - DeepSeek: 64K context → threshold ~20K
# - Qwen: 32K context → threshold ~10K
SUMMARIZATION_TOKEN_THRESHOLD=20000
MESSAGES_TO_KEEP=10

# RetryMiddleware - LLM/工具调用失败自动重试
MODEL_MAX_RETRIES=3
TOOL_MAX_RETRIES=3

# FilesystemMiddleware - 大结果自动转存阈值（tokens）
FILESYSTEM_TOKEN_LIMIT=20000

# HumanInTheLoopMiddleware - 需要人工确认的工具（逗号分隔，留空禁用）
# 示例: INTERRUPT_ON=write_todos,execute_query
INTERRUPT_ON=


# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/tableau_assistant.log
